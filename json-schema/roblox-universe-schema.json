{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://api-evangelist.github.io/roblox-engine-api/json-schema/roblox-universe-schema.json",
  "title": "Roblox Universe",
  "description": "Schema for a Roblox experience (universe) resource from the Open Cloud API.",
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "description": "Unique universe identifier"
    },
    "displayName": {
      "type": "string",
      "description": "Public display name of the experience"
    },
    "description": {
      "type": "string",
      "description": "Description of the experience"
    },
    "visibility": {
      "type": "string",
      "enum": ["public", "private"],
      "description": "Whether the experience is publicly visible"
    },
    "socialLinks": {
      "type": "array",
      "description": "Associated social media links",
      "items": {
        "type": "object",
        "properties": {
          "type": { "type": "string" },
          "url": { "type": "string", "format": "uri" }
        }
      }
    },
    "createTime": {
      "type": "string",
      "format": "date-time",
      "description": "Timestamp when the universe was created"
    },
    "updateTime": {
      "type": "string",
      "format": "date-time",
      "description": "Timestamp of the last update"
    }
  },
  "required": ["id", "displayName"]
}
